# --- INSIGHT-AI CONFIGURATION TEMPLATE ---
# Rename this file to .env and add your private keys below.

# Primary Provider (groq, gemini, openai, huggingface)
LLM_PROVIDER=groq

# --- GROQ SETTINGS ---
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- GEMINI SETTINGS (Optional) ---
# Get your key at: https://aistudio.google.com/
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- OPENAI SETTINGS (Optional) ---
# Get your key at: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- HUGGINGFACE SETTINGS (Optional) ---
# Get your key at: https://huggingface.co/settings/tokens
# HF_TOKEN=your_hf_token_here
# HF_MODEL=microsoft/Phi-3-mini-4k-instruct
